# Copy this file to .env and fill in the values before running:
#   docker compose up --build
#
# .env is listed in .gitignore and must never be committed to source control.

# ── Required ───────────────────────────────────────────────────────────────

# Secret used to sign JWT tokens.  Must be a long, random string.
# Generate one with:  openssl rand -base64 64
JWT_KEY=replace-this-with-a-long-random-secret

# ── Optional ───────────────────────────────────────────────────────────────

# Host port the application is served on (default: 80).
# PORT=80
